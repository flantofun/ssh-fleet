{
  "name": "ssh-fleet",
  "version": "0.2.0",
  "description": "A lightweight CLI tool to manage and execute commands across multiple SSH servers in parallel.",
  "type": "module",
  "bin": {
    "ssh-fleet": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "judge": "node scripts/judge.mjs",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test test/*.test.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ssh",
    "fleet",
    "parallel",
    "remote-execution",
    "devops",
    "sysadmin",
    "cli"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "ssh2": "^1.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/ssh2": "^1.15.5",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
